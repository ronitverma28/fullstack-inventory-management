{
  "expo": {
    "name": "MY INVENTORY",
    "slug": "inventory",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/ronit.png",
    "scheme": "inventorymanagment",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/ronit.png",
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.ronit.fullstackinventory"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/ronit.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/ronit.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "d56f4ded-7d3f-4bd7-8248-dd1a73786834"
      }
    }
  }
}